# ── Copy this file to .env.local and fill in real values ──────────────────
# .env.local is git-ignored and never committed.

# ── Map tiles (browser-safe) ───────────────────────────────────────────────
# OSM-compatible raster tile provider — NEVER the public tile.openstreetmap.org
# demo server (not licensed for unlimited production traffic). Sign up for a
# free-tier key at https://www.maptiler.com/cloud/ or https://stadiamaps.com/,
# or point this at your own self-hosted tile server.
VITE_MAP_TILE_URL=https://api.maptiler.com/maps/streets-v2/{z}/{x}/{y}.png?key=your_maptiler_key_here
VITE_MAP_TILE_ATTRIBUTION=© OpenStreetMap contributors © MapTiler

# ── Geocoding + routing (browser-safe) ─────────────────────────────────────
# OpenRouteService — free-tier API key from https://openrouteservice.org/dev/#/signup
# Powers address autocomplete/geocoding (Order Book) and road-following route
# lines (map). Restrict the key by HTTP referrer in the ORS dashboard.
VITE_ORS_API_KEY=your_openrouteservice_api_key_here
# VITE_ORS_BASE_URL=https://api.openrouteservice.org

# Alternate routing backend — set VITE_ROUTING_PROVIDER=osrm and point this at
# your own self-hosted/managed OSRM instance (never the public demo router).
# VITE_ROUTING_PROVIDER=osrm
# VITE_OSRM_BASE_URL=https://osrm.your-domain.com

# ── Supabase (browser-safe — VITE_ prefix = included in bundle) ───────────
# Get from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_key_here

# ── Server-side only (NEVER use VITE_ prefix on these) ───────────────────
# These are set in Vercel / GitHub Actions secrets — NOT in .env.local
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   ← bypasses RLS, never expose
# GEMINI_API_KEY=your_gemini_key

# ── Gemini AI (for local server dev only) ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── OR-Tools VRP solver ─────────────────────────────────────────────────────
# No API key needed — runs as a Python function (api/optimize.py on Vercel,
# or spawned locally by server.ts via `python3 api/optimize_cli.py`).
# Requires `pip install -r requirements.txt` (installs `ortools`) locally.
# If unreachable, the app falls back to the in-browser heuristic automatically.
