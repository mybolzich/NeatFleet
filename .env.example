# ── Copy this file to .env.local and fill in real values ──────────────────
# .env.local is git-ignored and never committed.

# ── Google Maps (existing) ────────────────────────────────────────────────
# Enables Maps JavaScript API, Places Autocomplete, Geocoding
GOOGLE_MAPS_PLATFORM_KEY=your_google_maps_api_key_here

# ── Supabase (browser-safe — VITE_ prefix = included in bundle) ───────────
# Get from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_key_here

# ── Server-side only (NEVER use VITE_ prefix on these) ───────────────────
# These are set in Vercel / GitHub Actions secrets — NOT in .env.local
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   ← bypasses RLS, never expose
# GEMINI_API_KEY=your_gemini_key

# ── Gemini AI (for local server dev only) ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
